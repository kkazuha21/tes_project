        <BeanShellPreProcessor guiclass="TestBeanGUI" testclass="BeanShellPreProcessor" testname="生成预约时间" enabled="true">
          <stringProp name="script">import java.text.SimpleDateFormat;
import java.util.Calendar;

// 获取线程号（从0开始）和循环次数
int threadNum = ctx.getThreadNum();
int iteration = vars.getIteration();

// 计算唯一的天数偏移：考虑线程数和循环次数
// 假设最多100个线程，每个线程的每次迭代预约不同的一天
int uniqueDay = threadNum + (iteration * 100) + 1;  // 从第1天开始

// 从2029年1月1日开始计算日期
Calendar cal = Calendar.getInstance();
cal.set(2029, 0, 1);  // 设置为2029年1月1日
cal.add(Calendar.DAY_OF_MONTH, uniqueDay - 1);  // 加上偏移天数

// 统一预约时间：8:00-9:00（1小时）
cal.set(Calendar.HOUR_OF_DAY, 8);
cal.set(Calendar.MINUTE, 0);
cal.set(Calendar.SECOND, 0);
cal.set(Calendar.MILLISECOND, 0);
SimpleDateFormat sdf = new SimpleDateFormat(&quot;yyyy-MM-dd&apos;T&apos;HH:mm:ss&quot;);
String startTime = sdf.format(cal.getTime());

// 设置结束时间（+1小时）
cal.add(Calendar.HOUR_OF_DAY, 1);
String endTime = sdf.format(cal.getTime());

// 保存到变量
vars.put(&quot;startTime&quot;, startTime);
vars.put(&quot;endTime&quot;, endTime);</stringProp>
          <boolProp name="resetInterpreter">false</boolProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
        </BeanShellPreProcessor>
